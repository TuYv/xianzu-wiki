{
  "characters": [
    {
      "id": 1,
      "name": "陆江仙",
      "aliases": [
        "鉴子",
        "镜灵"
      ],
      "gender": "male",
      "generation": null,
      "realm": "器灵·月华(吞玉石后神识二十丈)",
      "affiliation": "黎泾村·李家(器灵)",
      "status": "alive",
      "bio": "现代加班族猝死后，神魂寄附于眉尺河底一面灰青破镜，化为修『月华』的器灵，被李项平打捞回李家。吞下卡在望月湖石缝的玉石后，习得《太阴吐纳养轮经》与本命《玄珠祀灵术》，神识扩张能探人心思、可凝玄珠符种助人修行。心思谨慎自嘲，藏起灵智暗中谋划属于自己的仙路。",
      "avatar_url": null
    },
    {
      "id": 2,
      "name": "李木田",
      "aliases": [
        "木田叔",
        "李叔"
      ],
      "gender": "male",
      "generation": "黎泾村李家·家主",
      "realm": "凡人",
      "affiliation": "黎泾村·李家",
      "status": "alive",
      "bio": "年近六十的退伍老兵，黎泾村李家家主。十三岁离乡沿古黎道从军，被杨将军征去攻打山越，杀人无数后带军饷回乡置地成大户。刚硬果决、城府极深，得鉴子后立祠堂、建大院、定家规，谋借仙缘兴族，又怕招祸灭门，急着为儿子定亲传嗣。",
      "avatar_url": null
    },
    {
      "id": 3,
      "name": "柳林云",
      "aliases": [],
      "gender": "female",
      "generation": "李家·主母",
      "realm": "凡人",
      "affiliation": "黎泾村·李家",
      "status": "alive",
      "bio": "李木田之妻，李家四兄弟的生母。温和持家，戏份多在灶台与家宴之间，是李家安稳的后方。",
      "avatar_url": null
    },
    {
      "id": 4,
      "name": "李长湖",
      "aliases": [],
      "gender": "male",
      "generation": "李家·长子",
      "realm": "凡人(习《接引法》白毫三寸，待接引符种)",
      "affiliation": "黎泾村·李家",
      "status": "alive",
      "bio": "李家长子，十七岁已蓄须，处事圆滑、为人宽厚，被父亲视为承嗣之选，已娶任家次女为妻。修习《接引法》仅显白毫三寸，与玄珠符种契合度最低。",
      "avatar_url": null
    },
    {
      "id": 5,
      "name": "李通崖",
      "aliases": [],
      "gender": "male",
      "generation": "李家·次子",
      "realm": "凡人(习《接引法》白毫六寸，待接引符种)",
      "affiliation": "黎泾村·李家",
      "status": "alive",
      "bio": "李家次子，十八岁仍未娶妻，勇敢果决、敢打敢拼又识字明理。曾泅水入望月湖取回玉石，一度主张灭口李叶盛以绝后患；白毫六寸，立志踏上修仙之路。",
      "avatar_url": null
    },
    {
      "id": 6,
      "name": "李项平",
      "aliases": [
        "项平哥"
      ],
      "gender": "male",
      "generation": "李家·三子",
      "realm": "凡人(习《接引法》白毫五寸，待接引符种)",
      "affiliation": "黎泾村·李家",
      "status": "alive",
      "bio": "李家三子，眉清目秀、机灵狡黠却读书不成。在眉尺河捡到破镜鉴子，是引动全家仙缘的关键人物。与田芸两情相悦，第十章由父亲提雁纳采定下婚约；白毫五寸。",
      "avatar_url": null
    },
    {
      "id": 7,
      "name": "李尺泾",
      "aliases": [
        "泾儿"
      ],
      "gender": "male",
      "generation": "李家·幼子",
      "realm": "胎息·月华养轮(白毫八寸，将凝玄景轮)",
      "affiliation": "黎泾村·李家",
      "status": "alive",
      "bio": "李家幼子，约九岁，聪慧俊美、读书最多。李家第一个接引玄珠符种、跨入修仙之门者，借鉴子月华加速吞纳，将凝成第一轮玄景轮；白毫八寸，契合度最高。",
      "avatar_url": null
    },
    {
      "id": 8,
      "name": "田芸",
      "aliases": [
        "芸妹"
      ],
      "gender": "female",
      "generation": "田家·女",
      "realm": "凡人",
      "affiliation": "黎泾村·田家",
      "status": "alive",
      "bio": "田守水之女，圆脸朴实、笑容讨喜的村姑，自幼便认定李项平为夫君。第十章李木田提着大雁上门纳采，与李项平正式定亲。",
      "avatar_url": null
    },
    {
      "id": 9,
      "name": "田守水",
      "aliases": [
        "田叔"
      ],
      "gender": "male",
      "generation": "田家·家主",
      "realm": "凡人",
      "affiliation": "黎泾村·田家",
      "status": "alive",
      "bio": "田芸之父，黎泾村出名厚道的农户，也是李木田的军中结义兄弟——五岁起便跟在李木田身后，十二岁与任平安一同从军，三人抱团求生。回乡后与李家休戚与共，曾参与诛灭元家，连李长湖都是他亲手带大。",
      "avatar_url": null
    },
    {
      "id": 10,
      "name": "李叶生",
      "aliases": [
        "叶弟儿"
      ],
      "gender": "male",
      "generation": "李家堂支·弟",
      "realm": "凡人",
      "affiliation": "黎泾村·李家(堂支)",
      "status": "alive",
      "bio": "放鸭少年，李项平的玩伴，李家堂亲子弟。性子怯懦胆小，常被兄长李叶盛打骂驱使，被逼去李家偷瓜探虚实。",
      "avatar_url": null
    },
    {
      "id": 11,
      "name": "李叶盛",
      "aliases": [
        "叶盛",
        "叶盛哥"
      ],
      "gender": "male",
      "generation": "李家堂支·兄",
      "realm": "凡人",
      "affiliation": "黎泾村·李家(堂支)",
      "status": "alive",
      "bio": "李家堂亲子弟，好吃懒做、薄情张扬，常到李家打秋风。半夜偷瓜被李木田当场从瓜田拎出，因恐撞见鉴子之秘险些被李通崖灭口；事后反生贪念，惦记李木田家财，指使弟弟李叶生再去偷瓜探虚实。",
      "avatar_url": null
    },
    {
      "id": 12,
      "name": "韩文许",
      "aliases": [
        "韩先生",
        "先生"
      ],
      "gender": "male",
      "generation": null,
      "realm": "凡人",
      "affiliation": "黎泾村",
      "status": "alive",
      "bio": "黎泾村塾师，李家子弟的启蒙先生。十二岁那年亲见仙人到镇上挑选开窍幼童带走，自此对仙缘念念不忘、怅惘半生；与李木田交好。",
      "avatar_url": null
    },
